# GEMINI_API_KEY: Required for all Gemini AI calls (stress-test, evaluation,
# brand guide, and structuring market research).
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# TAVILY_API_KEY: Required for live online market research (independent web
# search, no Google). Free tier — get a key at https://tavily.com.
# Without it, market research falls back to a labeled offline preview.
TAVILY_API_KEY="MY_TAVILY_API_KEY"

# SUPABASE_URL / SUPABASE_ANON_KEY: User accounts + cloud save (email/password).
# Free project at https://supabase.com (Settings → API). The anon key is safe
# to expose — Row-Level Security enforces access. Without these, the app runs
# in local-only mode (work saved in the browser only).
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY="MY_SUPABASE_ANON_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
